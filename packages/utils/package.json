{
  "name": "@corvu-next/utils",
  "version": "0.1.4",
  "description": "Utilities for @corvu-next (Solid 2 fork)",
  "license": "MIT",
  "author": {
    "name": "Jasmin Noetzli (upstream), @corvu-next contributors (fork)",
    "email": "code@jasi.dev",
    "url": "https://github.com/GiyoMoon"
  },
  "homepage": "https://corvu.dev",
  "bugs": {
    "url": "https://github.com/corvudev/corvu/issues",
    "email": "code@jasi.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opencenter-cloud/corvu-next.git",
    "directory": "packages/utils"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "solid",
    "solidjs",
    "headless",
    "accessible",
    "customizable"
  ],
  "exports": {
    ".": {
      "solid": "./dist/index.jsx",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "solid": "./dist/*/index.jsx",
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    },
    "./components/*": {
      "solid": "./dist/components/*.jsx",
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./create/*": {
      "solid": "./dist/create/*.jsx",
      "types": "./dist/create/*.d.ts",
      "default": "./dist/create/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "dom": [
        "./dist/dom/index.d.ts"
      ],
      "dynamic": [
        "./dist/dynamic/index.d.ts"
      ],
      "floating": [
        "./dist/floating/index.d.ts"
      ],
      "reactivity": [
        "./dist/reactivity/index.d.ts"
      ],
      "scroll": [
        "./dist/scroll/index.d.ts"
      ],
      "components/*": [
        "./dist/components/*.d.ts"
      ],
      "create/*": [
        "./dist/create/*.d.ts"
      ]
    }
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.3"
  },
  "peerDependencies": {
    "solid-js": "2.0.0-beta.19",
    "@solidjs/web": "2.0.0-beta.19"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.19",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "2.0.0-beta.19",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo dist node_modules",
    "lint": "tsc --noEmit",
    "typedoc": "typedoc --json api.json --entryPoints ./src/index.ts --tsconfig ./tsconfig.json"
  }
}
