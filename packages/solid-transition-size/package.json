{
  "name": "@corvu-next/transition-size",
  "version": "0.1.4",
  "description": "SolidJS 2 utility for animating element size transitions.",
  "license": "MIT",
  "author": {
    "name": "Jasmin Noetzli (upstream), @corvu-next contributors (fork)"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "solid": "./dist/index.jsx",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@corvu-next/utils": "0.1.4"
  },
  "peerDependencies": {
    "solid-js": "2.0.0-beta.19"
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.19",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "2.0.0-beta.19",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo dist node_modules",
    "lint": "tsc --noEmit",
    "typedoc": "typedoc --json api.json --entryPoints ./src/index.ts --tsconfig ./tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opencenter-cloud/corvu-next.git",
    "directory": "packages/solid-transition-size"
  }
}
