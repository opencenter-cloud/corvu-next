{
  "name": "@corvu-next/unocss",
  "version": "0.1.2",
  "description": "UnoCSS plugin for @corvu-next data attributes.",
  "license": "MIT",
  "author": {
    "name": "Jasmin Noetzli (upstream), @corvu-next contributors (fork)"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@unocss/core": "66.4.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo dist node_modules",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opencenter-cloud/corvu-next.git",
    "directory": "packages/unocss"
  }
}
