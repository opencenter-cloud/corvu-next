  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.15",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "2.0.0-beta.15",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf .turbo dist node_modules",
    "lint": "tsc --noEmit"
