  "description": "SolidJS 2 utility that manages the presence of an element in the DOM while being aware of pending animations.",
  "license": "MIT",
  "author": {
    "name": "Jasmin Noetzli (upstream), @corvu-next contributors (fork)",
    "email": "code@jasi.dev",
