  "peerDependencies": { "tailwindcss": ">=3" },
  "devDependencies": { "tailwindcss": "^3.4.0", "tsup": "^8.5.0", "typescript": "^5.9.2" },
  "scripts": { "build": "tsup", "clean": "rm -rf .turbo dist node_modules", "lint": "tsc --noEmit" }
